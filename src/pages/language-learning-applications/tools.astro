---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Language Learning Apps - Tools & Resources";
const description = "App evaluation frameworks, feature comparison tools, and resources for selecting effective language learning applications.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL}>
  <article>
    <h1>Tools & Resources for Evaluating Language Learning Apps</h1>
    
    <section>
      <h2>Tool 1: App Scorer — Evaluate Any Language App</h2>
      <p>Use this scoring framework to objectively evaluate any language learning app before committing time and money to it.</p>
      <div class="tool-box">
        <h3>Pedagogy Score (0–40 points)</h3>
        <ul>
          <li><strong>Spaced repetition system present:</strong> +10 pts</li>
          <li><strong>Speaking/output exercises included:</strong> +10 pts</li>
          <li><strong>Immediate corrective feedback:</strong> +10 pts</li>
          <li><strong>Content uses real-world context (not isolated drills):</strong> +10 pts</li>
        </ul>
        <h3>Engagement Score (0–30 points)</h3>
        <ul>
          <li><strong>Adaptive difficulty (adjusts to your level):</strong> +10 pts</li>
          <li><strong>Progress tracking with visible milestones:</strong> +10 pts</li>
          <li><strong>Social or community features:</strong> +10 pts</li>
        </ul>
        <h3>Practical Score (0–30 points)</h3>
        <ul>
          <li><strong>Offline mode available:</strong> +10 pts</li>
          <li><strong>No intrusive ads disrupting sessions:</strong> +10 pts</li>
          <li><strong>Clear privacy policy, no aggressive data selling:</strong> +10 pts</li>
        </ul>
        <p><strong>Score 80–100:</strong> Excellent choice. <strong>60–79:</strong> Good with caveats. <strong>Below 60:</strong> Look for alternatives.</p>
      </div>
    </section>

    <section>
      <h2>Tool 2: App Finder — Match Goals to App Type</h2>
      <p>Select your primary learning goal to find the right type of app.</p>
      <div class="tool-box">
        <div class="tool-input">
          <label for="goal">My primary language learning goal:</label>
          <select id="goal">
            <option value="vocab">Build vocabulary fast</option>
            <option value="speak">Improve speaking and pronunciation</option>
            <option value="grammar">Master grammar rules</option>
            <option value="listen">Improve listening comprehension</option>
            <option value="casual">Casual daily practice, stay consistent</option>
            <option value="exchange">Find native speakers to practice with</option>
          </select>
          <button onclick="matchApp()">Find My App Type</button>
        </div>
        <div id="appResult" class="tool-output" style="display:none;">
          <h4>Recommended App Type</h4>
          <p id="appRecommendation"></p>
          <p id="appExamples"></p>
        </div>
      </div>
    </section>

    <section>
      <h2>Tool 3: Study Time Calculator</h2>
      <p>Estimate how long it will take to reach your target proficiency level with consistent daily app use.</p>
      <div class="tool-box">
        <div class="tool-input">
          <label for="currentLevel">Current level:</label>
          <select id="currentLevel">
            <option value="0">Complete beginner (A0)</option>
            <option value="1">Basic (A1)</option>
            <option value="2">Elementary (A2)</option>
            <option value="3">Intermediate (B1)</option>
            <option value="4">Upper intermediate (B2)</option>
          </select>

          <label for="targetLevel">Target level:</label>
          <select id="targetLevel">
            <option value="1">Basic (A1)</option>
            <option value="2">Elementary (A2)</option>
            <option value="3">Intermediate (B1)</option>
            <option value="4">Upper intermediate (B2)</option>
            <option value="5">Advanced (C1)</option>
          </select>

          <label for="dailyMinutes">Minutes per day using the app:</label>
          <input type="number" id="dailyMinutes" value="20" min="5" max="120">

          <button onclick="calcStudyTime()">Calculate</button>
        </div>
        <div id="studyResult" class="tool-output" style="display:none;">
          <h4>Estimated Study Time</h4>
          <p id="studyEstimate"></p>
          <p id="studyNote"></p>
        </div>
      </div>
    </section>

    <section>
      <h2>Top App Recommendations by Category</h2>
      <ul>
        <li><strong>Best for gamification &amp; consistency:</strong> Duolingo — free, streak-based, 40+ languages</li>
        <li><strong>Best for structured grammar:</strong> Babbel — human-designed lessons, real-world focus</li>
        <li><strong>Best for vocabulary (spaced repetition):</strong> Anki — fully customizable flashcard decks</li>
        <li><strong>Best for speaking practice:</strong> iTalki — connects with human tutors and language partners</li>
        <li><strong>Best for language exchange:</strong> Tandem / HelloTalk — community of millions of native speakers</li>
        <li><strong>Best for immersive listening:</strong> Lingopie — real TV shows and movies with interactive subtitles</li>
        <li><strong>Best all-in-one platform:</strong> Busuu — vocabulary, grammar, speaking, and native speaker feedback</li>
      </ul>
    </section>

    <section>
      <h2>Exploring Further</h2>
      <p>For more context on language learning apps:</p>
      <ul>
        <li>Review the <a href="/language-learning-applications/">overview</a> of app types and principles</li>
        <li>Understand the <a href="/language-learning-applications/technical-deep-dive/">technical architecture</a> behind these tools</li>
        <li>Explore <a href="/language-learning-applications/ontology/">detailed terminology</a> in our knowledge base</li>
        <li>Address <a href="/language-learning-applications/challenges/">common challenges</a> with app-based learning</li>
      </ul>
    </section>
  </article>

  <style>
    article {
      max-width: 900px;
      margin: 0 auto;
    }

    h1 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      color: #2c3e50;
    }

    h2 {
      font-size: 1.5rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
      color: #34495e;
      border-bottom: 2px solid #667eea;
      padding-bottom: 0.5rem;
    }

    h3 {
      font-size: 1.2rem;
      margin-top: 1rem;
      color: #555;
    }

    section {
      margin-bottom: 2rem;
    }

    p {
      margin-bottom: 1rem;
      line-height: 1.8;
      color: #444;
    }

    .tool-box {
      background: #f9f9f9;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 1.5rem;
      margin: 1.5rem 0;
    }

    .tool-input {
      background: white;
      padding: 1rem;
      border-radius: 4px;
      margin: 1rem 0;
    }

    .tool-input label {
      display: block;
      margin-top: 1rem;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: #333;
    }

    .tool-input input,
    .tool-input textarea,
    .tool-input select {
      width: 100%;
      padding: 0.5rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-family: inherit;
      font-size: 1rem;
    }

    .tool-input textarea {
      min-height: 80px;
      resize: vertical;
    }

    .tool-input button {
      margin-top: 1rem;
      padding: 0.75rem 1.5rem;
      background-color: #667eea;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 500;
    }

    .tool-input button:hover {
      background-color: #764ba2;
    }

    .tool-output {
      background: #e8f4f8;
      padding: 1rem;
      border-radius: 4px;
      border-left: 4px solid #667eea;
      margin-top: 1rem;
    }

    .tool-output h4 {
      color: #667eea;
      margin-top: 0;
    }

    .tool-output p {
      margin-bottom: 0.5rem;
    }

    .tool-output ul {
      margin-left: 1.5rem;
    }

    .tool-output li {
      margin-bottom: 0.5rem;
    }

    ul {
      margin-left: 2rem;
      margin-bottom: 1rem;
    }

    li {
      margin-bottom: 0.5rem;
      line-height: 1.6;
      color: #444;
    }

    a {
      color: #667eea;
      text-decoration: none;
      border-bottom: 1px dotted #667eea;
    }

    a:hover {
      color: #764ba2;
      border-bottom-color: #764ba2;
    }
  </style>

  <script is:inline>
    function analyzeSentence() {
      const sentence = document.getElementById('sentence').value;
      if (!sentence) {
        alert('Please enter a sentence');
        return;
      }
      
      const result = document.getElementById('analysisResult');
      document.getElementById('errorExplanation').textContent = 'Example: "He go" - Missing third-person singular marker (-s)';
      document.getElementById('slaExplanation').textContent = 'SLA Principle: Incomplete learning of morphosyntax. The learner has not yet internalized the rule that third-person singular present tense requires -s.';
      document.getElementById('suggestion').textContent = 'Suggestion: Focus on input containing third-person singular forms. Notice the pattern: "He goes, She goes, It goes." Practice producing sentences with this structure.';
      result.style.display = 'block';
    }

    function matchLearningCondition() {
      const age = document.getElementById('age').value;
      const time = document.getElementById('time').value;
      const context = document.getElementById('context').value;
      
      const result = document.getElementById('matchResult');
      document.getElementById('matchExplanation').textContent = 'Based on your learning context, here are personalized recommendations from SLA research:';
      
      const recommendations = document.getElementById('recommendations');
      recommendations.innerHTML = '';
      
      const recs = [
        'Prioritize comprehensible input: Read and listen to content slightly above your level',
        'Engage in meaningful interaction: Seek conversation partners or language exchange',
        'Practice output regularly: Speak and write daily, even if just for 15 minutes',
        'Use spaced repetition for vocabulary: Review new words at increasing intervals',
        'Lower your affective filter: Create a supportive learning environment, reduce anxiety'
      ];
      
      recs.forEach(rec => {
        const li = document.createElement('li');
        li.textContent = rec;
        recommendations.appendChild(li);
      });
      
      result.style.display = 'block';
    }

    function calculateVocabTimeline() {
      const targetVocab = parseInt(document.getElementById('targetVocab').value);
      const hoursPerWeek = parseInt(document.getElementById('hoursPerWeek').value);
      
      if (!targetVocab || !hoursPerWeek) {
        alert('Please enter valid numbers');
        return;
      }
      
      // Based on Nation's research: ~100-150 words per 10 hours of study
      const wordsPerHour = 12.5;
      const totalHours = targetVocab / wordsPerHour;
      const weeks = totalHours / hoursPerWeek;
      const months = weeks / 4.3;
      
      const result = document.getElementById('vocabResult');
      document.getElementById('timelineExplanation').textContent = 'Based on research by Paul Nation and others:';
      document.getElementById('timelineResult').textContent = `To acquire ${targetVocab} words at ${hoursPerWeek} hours/week: approximately ${Math.round(weeks)} weeks (${Math.round(months)} months)`;
      document.getElementById('timelineNote').textContent = 'Note: This assumes quality study (spaced repetition, meaningful use). Actual timeline varies based on motivation, learning strategies, and exposure to authentic input.';
      result.style.display = 'block';
    }
  </script>
</BaseLayout>
